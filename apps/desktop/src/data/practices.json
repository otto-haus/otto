  {
    "name": "Field Note",
    "slug": "field-note",
    "version": "0.1",
    "status": "draft",
    "summary": "Capture messy customer/operator/research notes into durable structured state.",
    "invocations": [
      "/field-note capture"
    ],
    "triggers": [
      "raw customer / operator / user note",
      "voice memo or post-meeting brain dump",
      "research observation worth keeping"
    ],
    "inputs": [
      "raw note",
      "source / context (who, role, where, when)"
    ],
    "outputs": [
      "raw note",
      "source/context",
      "exact quotes (verbatim signal)",
      "entities",
      "insights",
      "open questions",
      "follow-up candidates",
      "memory writeback suggestions"
    ],
    "state_paths": [
      "field-notes/"
    ],
    "guardrails": [
      "capture verbatim signal, not paraphrase (especially objections + exact words)",
      "stage the next follow-up; never auto-send",
      "the office/customer decides; we only record"
    ],
    "evidence_standard": [
      "who/where/when captured",
      "exact quotes preserved",
      "at least one insight or open question",
      "one staged (not sent) follow-up candidate"
    ],
    "metrics": [
      "uses",
      "notes_captured",
      "followups_staged",
      "memory_writebacks"
    ],
    "owner": "Vinny",
    "approval_required_for": [
      "enabling-globally",
      "external-side-effects",
      "permission-expansion",
      "send-or-publish"
    ]
  },
  {
    "name": "Follow-up",
    "slug": "follow-up",
    "version": "0.1",
    "status": "draft",
    "summary": "Draft relationship/customer follow-ups with explicit approval gates.",
    "invocations": [
      "/follow-up draft"
    ],
    "triggers": [
      "a field note produced a follow-up candidate",
      "a relationship/customer touch is owed",
      "a thread needs a next step"
    ],
    "inputs": [
      "context (often from a field note)",
      "recipient",
      "desired outcome"
    ],
    "outputs": [
      "draft",
      "source context",
      "recipient",
      "risk notes",
      "approval card"
    ],
    "state_paths": [
      "follow-ups/"
    ],
    "guardrails": [
      "NO-SEND-WITHOUT-APPROVAL — drafts only; never send/post/publish autonomously",
      "every draft renders an approval card before any outbound action",
      "cite the source context the draft is based on (no invented facts)"
    ],
    "evidence_standard": [
      "draft tied to a real source/context",
      "recipient + risk notes present",
      "approval card generated; send blocked until approved"
    ],
    "metrics": [
      "uses",
      "drafts_created",
      "sends_after_approval",
      "user_edits_required"
    ],
    "owner": "Vinny",
    "approval_required_for": [
      "enabling-globally",
      "external-side-effects",
      "permission-expansion",
      "send-or-publish"
    ]
  },
  {
    "name": "Review",
    "slug": "review",
    "version": "0.1",
    "status": "draft",
    "summary": "Prevent fake done and premature completion by mapping claims to evidence.",
    "invocations": [
      "/review done",
      "/review risk"
    ],
    "triggers": [
      "a task is about to be marked done",
      "a claim of completion needs proof",
      "before a one-way door or handoff"
    ],
    "inputs": [
      "the work / claim of done",
      "acceptance criteria",
      "context and artifacts"
    ],
    "outputs": [
      "acceptance criteria map",
      "evidence checklist",
      "remaining risks",
      "cleanup notes",
      "pass/fail recommendation"
    ],
    "state_paths": [
      "reviews/"
    ],
    "guardrails": [
      "done requires mapped proof (claim -> evidence)",
      "any unmapped acceptance criterion => not done",
      "the Practice recommends; the human (or Charter's acceptance gate) decides"
    ],
    "evidence_standard": [
      "every acceptance criterion mapped to evidence",
      "remaining risks listed",
      "cleanup verified"
    ],
    "metrics": [
      "uses",
      "premature_done_prevented",
      "risks_flagged",
      "ac_unmapped"
    ],
    "owner": "Vinny",
    "approval_required_for": [
      "enabling-globally",
      "external-side-effects",
      "permission-expansion"
    ]
  }
