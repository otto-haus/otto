{
  "name": "@otto-haus/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Local desktop shell for otto.",
  "author": "otto haus",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "main": "./out/main/index.cjs",
  "scripts": {
    "predev": "bun run gen:practices && bun run gen:readiness",
    "dev": "vite",
    "prebuild": "bun run gen:practices && bun run gen:readiness",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "electron:typecheck": "tsc --noEmit -p tsconfig.electron.json",
    "electron:build": "bun run gen:readiness && electron-vite build",
    "electron:dev": "electron-vite dev",
    "gen:practices": "node scripts/gen-practices.mjs",
    "gen:readiness": "node scripts/gen-readiness.mjs",
    "gen:staging-icon": "node scripts/generate-staging-icon.mjs",
    "app:dir": "bun run electron:build && electron-builder --mac dir --arm64",
    "smoke:e2e": "playwright test",
    "smoke:e2e:two-thread": "playwright test e2e/two-thread.spec.ts",
    "smoke:e2e:onboarding": "playwright test e2e/onboarding.spec.ts"
  },
  "dependencies": {
    "@letta-ai/letta-client": "^1.12.1",
    "@letta-ai/letta-code": "0.19.5",
    "@letta-ai/letta-code-sdk": "^0.1.14",
    "@otto-haus/core": "workspace:*",
    "@vitejs/plugin-react": "latest",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.10.1",
    "drizzle-orm": "^0.45.2",
    "electron-window-state": "^5.0.3",
    "p-queue": "^9.3.0",
    "pg": "^8.21.0",
    "react": "latest",
    "react-dom": "latest",
    "streamdown": "2.5.0",
    "typescript": "latest",
    "vite": "latest",
    "ws": "^8.21.0",
    "yaml": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.61.0",
    "@types/archiver": "^6.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.15.2",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/ws": "^8.18.1",
    "electron": "^42.4.0",
    "electron-builder": "26.15.3",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.28.1"
  }
}
